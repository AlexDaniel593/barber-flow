# PostgreSQL (una instancia, una base por microservicio: ver docker/init-databases.sql)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT (API Gateway)
JWT_SECRET=dev-secret-change-in-production

# Gateway microservice connections
SVC_PEDIDOS_HOST=appointments
SVC_PEDIDOS_PORT=3001
SVC_APPOINTMENTS_HOST=appointments
SVC_APPOINTMENTS_PORT=3001
SERVICES_STAFF_HOST=services-staff
SERVICES_STAFF_PORT=3002
SERVICES_INVENTORY_BILLING_HOST=inventory-billing
SERVICES_INVENTORY_BILLING_PORT=3003

# gRPC stylist validation
SVC_STYLIST_GRPC_HOST=services-staff:50051
